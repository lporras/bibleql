<% content_for(:title, "BibleQL — GraphQL API for Bible Verses") %>

<div class="w-full">
  <!-- Hero -->
  <section class="text-center py-16">
    <h1 class="text-5xl font-bold tracking-tight text-gray-900">
      BibleQL
    </h1>
    <p class="mt-4 text-xl text-gray-600 max-w-2xl mx-auto">
      A free, open-source GraphQL API for querying Bible verses and passages across multiple translations and languages.
    </p>
    <div class="mt-8 flex justify-center gap-4">
      <%= link_to "Get an API Key", new_api_key_request_path,
        class: "rounded-lg bg-indigo-600 px-6 py-3 text-white font-semibold hover:bg-indigo-500 transition" %>
      <%= link_to "Try the Playground", playground_path,
        class: "rounded-lg border border-gray-300 px-6 py-3 text-gray-700 font-semibold hover:bg-gray-50 transition" %>
      <a href="https://github.com/lporras/bibleql" target="_blank" rel="noopener noreferrer"
        class="rounded-lg border border-gray-300 px-6 py-3 text-gray-700 font-semibold hover:bg-gray-50 transition">
        View on GitHub
      </a>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-12 border-t border-gray-200">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-center max-w-3xl mx-auto">
      <div>
        <p class="text-4xl font-bold text-indigo-600"><%= number_with_delimiter(@translations_count) %></p>
        <p class="mt-1 text-gray-500">Translations</p>
      </div>
      <div>
        <p class="text-4xl font-bold text-indigo-600"><%= @languages_count %></p>
        <p class="mt-1 text-gray-500">Languages</p>
      </div>
      <div>
        <p class="text-4xl font-bold text-indigo-600"><%= number_with_delimiter(@verses_count) %></p>
        <p class="mt-1 text-gray-500">Verses</p>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-12 border-t border-gray-200">
    <h2 class="text-2xl font-bold text-center text-gray-900 mb-10">What You Can Do</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
      <div class="border border-gray-200 rounded-lg p-6">
        <h3 class="font-semibold text-lg text-gray-900">Passage Lookup</h3>
        <p class="mt-2 text-gray-600 text-sm">Query any passage by reference. Supports single verses, ranges, and multi-ranges.</p>
        <code class="mt-3 block text-xs text-indigo-600 bg-gray-50 rounded p-2">"John 3:16" &middot; "Matthew 25:31-33,46"</code>
      </div>
      <div class="border border-gray-200 rounded-lg p-6">
        <h3 class="font-semibold text-lg text-gray-900">Localized Book Names</h3>
        <p class="mt-2 text-gray-600 text-sm">Query using book names in the translation's language. Spanish, Chinese, German, and more.</p>
        <code class="mt-3 block text-xs text-indigo-600 bg-gray-50 rounded p-2">"Mateo 28:18-20" &middot; "G&eacute;nesis 1"</code>
      </div>
      <div class="border border-gray-200 rounded-lg p-6">
        <h3 class="font-semibold text-lg text-gray-900">Full-Text Search</h3>
        <p class="mt-2 text-gray-600 text-sm">Search for any word or phrase across all verses in a translation.</p>
        <code class="mt-3 block text-xs text-indigo-600 bg-gray-50 rounded p-2">search(query: "love", limit: 10)</code>
      </div>
      <div class="border border-gray-200 rounded-lg p-6">
        <h3 class="font-semibold text-lg text-gray-900">Multiple Translations</h3>
        <p class="mt-2 text-gray-600 text-sm">Access 43 Bible translations across 31 languages, all public domain.</p>
        <code class="mt-3 block text-xs text-indigo-600 bg-gray-50 rounded p-2">eng-web &middot; spa-bes &middot; chi-cuv &middot; ...</code>
      </div>
      <div class="border border-gray-200 rounded-lg p-6">
        <h3 class="font-semibold text-lg text-gray-900">Chapter & Verse</h3>
        <p class="mt-2 text-gray-600 text-sm">Retrieve full chapters or individual verses with structured data.</p>
        <code class="mt-3 block text-xs text-indigo-600 bg-gray-50 rounded p-2">chapter(book: "GEN", chapter: 1)</code>
      </div>
      <div class="border border-gray-200 rounded-lg p-6">
        <h3 class="font-semibold text-lg text-gray-900">Open Source</h3>
        <p class="mt-2 text-gray-600 text-sm">MIT licensed. Built with Rails, GraphQL, and open Bible data. Free to use, modify, and deploy.</p>
        <code class="mt-3 block text-xs text-indigo-600 bg-gray-50 rounded p-2">github.com/lporras/bibleql</code>
      </div>
    </div>
  </section>

  <!-- Example Query -->
  <section class="py-12 border-t border-gray-200">
    <h2 class="text-2xl font-bold text-center text-gray-900 mb-8">Example Query</h2>
    <div class="max-w-2xl mx-auto bg-gray-900 rounded-lg p-6 overflow-x-auto">
      <pre class="text-sm text-green-400"><code>{
  passage(translation: "eng-web", reference: "John 3:16") {
    reference
    text
    translationName
    verses {
      bookName
      chapter
      verse
      text
    }
  }
}</code></pre>
    </div>
    <p class="text-center mt-6">
      <%= link_to "Try it in the Playground &rarr;".html_safe, playground_path,
        class: "text-indigo-600 font-semibold hover:text-indigo-500" %>
    </p>
  </section>

  <!-- Footer -->
  <footer class="py-8 border-t border-gray-200 text-center text-sm text-gray-500">
    <p>
      BibleQL is open source under the
      <a href="https://github.com/lporras/bibleql/blob/main/LICENSE" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:underline">MIT License</a>.
      Bible data from
      <a href="https://github.com/seven1m/open-bibles" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:underline">open-bibles</a>.
    </p>
  </footer>
</div>
